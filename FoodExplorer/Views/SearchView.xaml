<UserControl x:Class="FoodExplorer.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FoodExplorer.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SearchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3674DA"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="0,8,8,0"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#3674DA"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border"
                            Background="White"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8,0,0,8">

                                <ScrollViewer x:Name="PART_ContentHost" 
                                      Focusable="false" 
                                      HorizontalScrollBarVisibility="Hidden" 
                                      VerticalScrollBarVisibility="Hidden"
                                      VerticalAlignment="Center"
                                      Margin="5,0"/>
                            </Border>

                            <TextBlock x:Name="PlaceholderText"
                               Text="{TemplateBinding Tag}"
                               Foreground="Black"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="15,0"
                               FontSize="{TemplateBinding FontSize}"
                               Visibility="Collapsed"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Product Search 🔍" FontSize="26" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15"/>
            <Grid Height="45">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" 
                         Style="{StaticResource SearchTextBoxStyle}"
                         Text="{Binding BarcodeSearchTerm, UpdateSourceTrigger=PropertyChanged}" 
                         FontSize="16"
                         Tag="Enter barcode..."/>

                <Button Grid.Column="1" 
                        Content="SEARCH" 
                        Style="{StaticResource SearchButtonStyle}"
                        Command="{Binding SearchCommand}" 
                        IsDefault="True"/>
            </Grid>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding SearchResults}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="12" Margin="0,0,5,20" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                    <Border CornerRadius="8" Background="#F9F9F9" Padding="5">
                                        <Image Width="120" Height="120" Stretch="Uniform"
                                               Source="{Binding ImageFrontSmallUrl, 
                                               TargetNullValue='/Assets/no_image_icon.png', 
                                               FallbackValue='/Assets/no_image_icon.png'}" />
                                    </Border>
                                    <TextBlock Text="Open Food Facts 🌐" FontSize="10" HorizontalAlignment="Center" Foreground="#AAA" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="22" FontWeight="Bold" Foreground="#2D3436" TextWrapping="Wrap"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,5">
                                        <Border Background="#E8F5E9" CornerRadius="4" Padding="8,3" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding NutriScore, StringFormat='Nutri-Score: {0}'}" 
                                                       FontSize="14" FontWeight="Bold" Foreground="#2E7D32"/>
                                        </Border>
                                        <TextBlock Text="{Binding BarCode, StringFormat='Barcode: {0}'}" 
                                                   FontSize="12" Foreground="Gray" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <Separator Margin="0,10" Background="#EEE"/>

                                    <TextBlock Text="Ingredients" FontWeight="Bold" Foreground="#555"/>
                                    <TextBlock Text="{Binding Ingredients}" TextWrapping="Wrap" FontSize="13" Margin="0,2,0,10" LineHeight="18"/>

                                    <TextBlock Text="Additives" FontWeight="Bold" Foreground="#555"/>
                                    <TextBlock Text="{Binding Additives}" TextWrapping="Wrap" Foreground="#C62828" FontSize="13" Margin="0,2,0,10"/>

                                    <TextBlock Text="Possible Traces" FontWeight="Bold" Foreground="#555"/>
                                    <TextBlock Text="{Binding Traces}" TextWrapping="Wrap" FontStyle="Italic" Foreground="#636E72" Margin="0,2,0,15"/>

                                    <Border Background="#F1F2F6" Padding="15" CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Nutrient Levels" FontWeight="Bold" FontSize="12" Margin="0,0,0,10" Foreground="#2D3436"/>
                                                <UniformGrid Columns="2">
                                                    <TextBlock Margin="0,2"><Run Text="Fat: " Foreground="#777"/><Run Text="{Binding NutrientLevels.Fat}" FontWeight="SemiBold"/></TextBlock>
                                                    <TextBlock Margin="0,2"><Run Text="Sat. Fat: " Foreground="#777"/><Run Text="{Binding NutrientLevels.SaturatedFat}" FontWeight="SemiBold"/></TextBlock>
                                                    <TextBlock Margin="0,2"><Run Text="Sugars: " Foreground="#777"/><Run Text="{Binding NutrientLevels.Sugars}" FontWeight="SemiBold"/></TextBlock>
                                                    <TextBlock Margin="0,2"><Run Text="Salt: " Foreground="#777"/><Run Text="{Binding NutrientLevels.Salt}" FontWeight="SemiBold"/></TextBlock>
                                                </UniformGrid>
                                            </StackPanel>

                                            <Button Grid.Column="1" 
                                                    Content="⭐ ADD TO FAVORITES" 
                                                    Command="{Binding DataContext.AddToFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#6EC422" Foreground="White" 
                                                    FontWeight="Bold" Padding="15,10" VerticalAlignment="Bottom">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#5BA81C"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                
                                                </Button.Resources>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>

</UserControl>