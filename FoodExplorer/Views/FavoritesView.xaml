<UserControl x:Class="FoodExplorer.Views.FavoritesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FoodExplorer.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="SaveButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1B5E20"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NoteTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="4" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" Background="White">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2E7D32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="My Favorite Products ⭐" FontSize="24" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FavoritesList}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#EEE" BorderThickness="1" Margin="0,0,0,10" Padding="15" CornerRadius="10" Background="White">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>

                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Content="🔍 Details" 
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Command="{Binding DataContext.ShowProductFromHistoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding Product}"
                                            Background="#3674DA" Foreground="White" BorderBrush="Transparent"
                                            Margin="0,0,8,0"/>

                                    <Button Content="🗑️ Remove" 
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Command="{Binding DataContext.DeleteFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}" 
                                            Background="#FFF0F0" Foreground="#D32F2F" BorderBrush="#FFCDD2"/>
                                </StackPanel>

                                <Image Source="{Binding Product.ImageFrontSmallUrl, TargetNullValue='/Assets/no_image_icon.png', FallbackValue='/Assets/no_image_icon.png'}" 
                                       Width="70" Height="70" Margin="0,0,20,0" Stretch="Uniform" VerticalAlignment="Top"/>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Product.Name}" FontSize="18" FontWeight="Bold" Foreground="#333"/>
                                    <TextBlock Text="{Binding Product.BarCode, StringFormat='Barcode: {0}'}" FontSize="12" Foreground="Gray" Margin="0,2"/>
                                    <TextBlock Text="{Binding AddedDate, StringFormat='Added on: {0:dd/MM/yyyy}'}" FontSize="11" Foreground="#2E7D32" Margin="0,0,0,8"/>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                 Tag="Add a personal note..."
                                                 Style="{StaticResource NoteTextBoxStyle}"
                                                 Width="250" Height="28" Margin="0,0,8,0"/>

                                        <Button Content="💾 Save" 
                                                Command="{Binding DataContext.EditNoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" 
                                                Style="{StaticResource SaveButtonStyle}"
                                                Padding="15,2"/>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
