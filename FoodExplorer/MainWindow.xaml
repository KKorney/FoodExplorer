<Window x:Class="FoodExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FoodExplorer.Views"
        xmlns:viewmodels="clr-namespace:FoodExplorer.ViewModels"
        Title="Food Explorer - Search" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:MainViewModel}">
            <views:SearchView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:FavoritesViewModel}">
            <views:FavoritesView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:HistoryViewModel}">
            <views:HistoryView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:ExportViewModel}">
            <views:ExportView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:ScannerViewModel}">
            <views:ScannerView />
        </DataTemplate>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">

            <Border Grid.Row="0" Background="#F0F0F0" CornerRadius="10" Padding="10" Margin="0,0,0,20">
                <UniformGrid Columns="5">
                    <Button Content="📷 Scan" Command="{Binding ShowScannerCommand}" 
                Background="#2196F3" Foreground="White" Margin="4" Height="40" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="🔍 Search" Command="{Binding ShowSearchCommand}" 
                Background="#3674DA" Foreground="White" Margin="4" Height="40" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="⭐ Favorites" Command="{Binding ShowFavoritesCommand}" 
                Background="#6EC422" Foreground="White" Margin="4" Height="40" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="📜 History" Command="{Binding ShowHistoryCommand}" 
                Background="#EAD511" Foreground="White" Margin="4" Height="40" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="📄 Export" Command="{Binding ShowExportCommand}" 
                Background="#ED0808" Foreground="White" Margin="4" Height="40" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </UniformGrid>
            </Border>

        </StackPanel>

        <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
    </Grid>
</Window>